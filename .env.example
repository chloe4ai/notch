# Copy this to `.env` and fill in.

# Where day-files live. Point at an iCloud or Dropbox folder to get sync for free.
# Example (iCloud Drive): /Users/chloetan/Library/Mobile Documents/com~apple~CloudDocs/LittleJot
# Example (Dropbox):      /Users/chloetan/Dropbox/LittleJot
# Default: ./data inside the project
DATA_DIR=./data

# Port the local server listens on
PORT=4174

# Anthropic API key for AI summaries. Without it, summaries fall back to a plain bullet list.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Which Claude model to use for summaries
ANTHROPIC_MODEL=claude-sonnet-4-6

# Times of day (24h, local) to auto-generate scheduled summaries.
# Comma-separated "HH:MM" pairs. Default: 12:00 (noon), 18:00 (evening), 21:00 (night).
SUMMARY_SCHEDULE=12:00,18:00,21:00

# Built-in activity tracking (macOS only). Set to `off` to disable auto-recording
# of app usage, window titles, and screenshots. Requires Accessibility + Screen
# Recording permissions for the terminal/app that runs `node`.
TRACKING=on

# --- Calendar integration (look forward) -----------------------------------
# A read-only ICS feed URL. Plans (daily & weekly) get grounded in your real
# meetings. Works without OAuth:
#   Google Calendar → Settings → your calendar → "Secret address in iCal format"
#   Apple Calendar  → right-click calendar → Share → Public Calendar (webcal/https .ics)
# Leave blank to skip — the planner still works, just without calendar context.
CALENDAR_ICS_URL=
